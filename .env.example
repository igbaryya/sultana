# Firebase configuration
#
# Copy this file to `.env` and fill in the values from your own Firebase
# project. The `.env` file is git-ignored and must never be committed.
#
# These values are injected into the client bundle at build time by webpack.

FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=
FIREBASE_DATABASE_URL=
FIREBASE_PROJECT_ID=
FIREBASE_STORAGE_BUCKET=
FIREBASE_MESSAGING_SENDER_ID=
FIREBASE_APP_ID=
FIREBASE_MEASUREMENT_ID=
